# =============================================================================
# Fraylon Certificate Verification — example env
#
# Copy this file to `.env.local` (gitignored) and fill in real values for local
# dev. NEVER commit real secrets. NEVER paste real secrets into chat. Generate
# the signing/salt values locally with:
#
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# Production values live in the Vercel project env (Next.js) and the Render
# service env (puppeteer-service). Synced once via password manager.
# =============================================================================

# ----- Supabase -------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-me
SUPABASE_SERVICE_ROLE_KEY=replace-me

# ----- Admin auth -----------------------------------------------------------
# Comma-separated allowlist. Real values live only in Vercel env.
ADMIN_EMAIL_ALLOWLIST=admin1@example.com,admin2@example.com

# ----- Signing --------------------------------------------------------------
# 32-byte (64 hex char) random string. Strict HMAC: changes to any signed
# field (incl. case/whitespace of recipient_name) must fail verification.
CERT_SIGNING_SECRET=replace-with-64-hex-chars

# 16-byte (32 hex char) random string. Salts the SHA-256 of verifier IPs in
# verification_logs so raw IPs never hit disk.
IP_HASH_SALT=replace-with-32-hex-chars

# ----- Puppeteer service (separate Render deployment) -----------------------
PUPPETEER_SERVICE_URL=https://fraylon-puppeteer.onrender.com
PUPPETEER_SERVICE_TOKEN=replace-with-shared-bearer-token

# ----- Upstash Redis (rate limit for /api/verify) ---------------------------
# Free tier — 10k commands/day. Created at https://console.upstash.com/
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace-me

# ----- Public --------------------------------------------------------------
NEXT_PUBLIC_VERIFY_BASE_URL=https://verify.fraylontech.com
